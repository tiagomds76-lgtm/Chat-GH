# Exemplo de variáveis de ambiente
# Copie este arquivo para .env apenas no seu computador ou servidor.
# Nunca coloque valores reais dentro deste arquivo no GitHub público.

APP_NAME=Chat-GH
APP_ENV=development
APP_URL=http://localhost:3000

DATABASE_URL=postgresql://usuario:senha@localhost:5432/nome_do_banco

OPENAI_API_KEY=coloque_somente_no_env_local
ANTHROPIC_API_KEY=coloque_somente_no_env_local
GITHUB_TOKEN=coloque_somente_no_env_local

JWT_SECRET=troque_por_um_segredo_forte_no_ambiente_real
